# Copy to .env.local for personal overrides (gitignored).
# Local API: pnpm dev (.env.development). Render API: pnpm dev:remote (.env.remote).
# Vercel production: see .env.production.example

# REST API base URL (Axios baseURL)
VITE_API_URL=/api

# Display name in sidebar, login, and browser title
VITE_APP_NAME=CMMS

# SignalR hub URL for real-time work order updates
VITE_SIGNALR_URL=/hubs/work-orders
